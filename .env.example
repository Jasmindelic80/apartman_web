# ===== KOPIRAJ OVO U .env (NE COMMITAJ .env NA GIT!) =====

# DJANGO
SECRET_KEY=generiraj-novi-tajni-kljuc-50-karaktera
DEBUG=False
ALLOWED_HOSTS=tvojeime.pythonanywhere.com,localhost,127.0.0.1

# BAZA (MySQL na PythonAnywhere - besplatno)
USE_MYSQL=True
DB_NAME=tvojeime$apartman
DB_USER=tvojeime
DB_PASSWORD=tvoja-mysql-lozinka
DB_HOST=tvojeime.mysql.pythonanywhere-services.com

# GOOGLE MAPS API
GOOGLE_MAPS_API_KEY=tvoj-maps-api-kljuc

# GMAIL (za slanje emailova)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tvojemail@gmail.com
EMAIL_HOST_PASSWORD=tvoja-app-lozinka-16-znakova
EMAIL_USE_TLS=True

# GEMINI AI
GEMINI_API_KEY=tvoj-gemini-api-kljuc

# PAYPAL (opciono)
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ICAL (opciono)
BOOKING_ICAL_URL=
AIRBNB_ICAL_URL=

# ANALYTICS (opciono)
GOOGLE_ANALYTICS_ID=
FACEBOOK_PIXEL_ID=
